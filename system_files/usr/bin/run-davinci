#!/bin/bash

export QT_QPA_PLATFORM=xcb
export QT_AUTO_SCREEN_SCALE_FACTOR=1

# Clear LD_LIBRARY_PATH inherited from the host to avoid broken paths
# (e.g. paths pointing to files instead of directories) causing crashes
unset LD_LIBRARY_PATH

GPU_TYPE=""
USE_RUSTICL=false
DAVINCI_BIN=""

get_gpu_type () {
  # Checks only for nvidia driver and not nouveau
  if lshw -c video 2>/dev/null | grep -qi "driver=nvidia"; then
    GPU_TYPE="nvidia"
  # Checks for amdgpu so that we can specify using rusticl by default
  elif lshw -c video 2>/dev/null | grep -qi "driver=amdgpu"; then
    GPU_TYPE="amd"
  # We don't have any special handling necessary for Intel GPUs at this time,
  # so we aren't currently checking for them.
  # In case we need to in the future, the Intel drivers are:
  # - driver=i915
  # - driver=xe
  fi
}

get_gpu_type

enable_rusticl () {
  export RUSTICL_ENABLE=radeonsi,iris,nouveau
  export OCL_ICD_VENDORS=rusticl.icd
}

get_host_dbus_socket () {
  for socket_path in \
    /run/host/var/run/dbus/system_bus_socket \
    /run/host/run/dbus/system_bus_socket
  do
    if [[ -S "$socket_path" ]]; then
      echo "$socket_path"
      return 0
    fi
  done

  return 1
}

while getopts "c" flag; do
  case "${flag}" in
    c) USE_RUSTICL=true;;
  esac
done

if [[ $USE_RUSTICL == true ]]; then
  enable_rusticl
fi

shift $((OPTIND - 1))

if [[ -n "$1" ]]; then  # Use -n for explicit non-empty string check
  DAVINCI_BIN=$(readlink -e "$1") # Quote $1 here
  if [[ -f "$DAVINCI_BIN" ]]; then
    echo "Launching $DAVINCI_BIN"
  else
    echo "$1 could not be found."
    exit 1
  fi
else
  echo "No path specified. Launching /opt/resolve/bin/resolve"
  DAVINCI_BIN="/opt/resolve/bin/resolve"
fi

# Remove empty config files that cause crashes on startup.
# DaVinci Resolve can truncate config.dat to 0 bytes if terminated
# unexpectedly, then crashes with a segfault on the next launch.
# Restore from the default config if available.
RESOLVE_CONFIG_DIR="${HOME}/.local/share/DaVinciResolve/configs"
DEFAULT_CONFIG="/opt/resolve/share/default-config.dat"
for cfg in "$RESOLVE_CONFIG_DIR/config.dat" "$RESOLVE_CONFIG_DIR/.config.data"; do
  if [[ -f "$cfg" && ! -s "$cfg" ]]; then
    rm -f "$cfg"
  fi
done
if [[ ! -f "$RESOLVE_CONFIG_DIR/config.dat" && -f "$DEFAULT_CONFIG" ]]; then
  mkdir -p "$RESOLVE_CONFIG_DIR"
  cp "$DEFAULT_CONFIG" "$RESOLVE_CONFIG_DIR/config.dat"
fi

# Copy log config from system default if missing or empty
if [[ ! -s "$RESOLVE_CONFIG_DIR/log-conf.xml" && -f /opt/resolve/share/log-conf.xml ]]; then
  cp /opt/resolve/share/log-conf.xml "$RESOLVE_CONFIG_DIR/log-conf.xml"
fi

if [[ "$GPU_TYPE" == "nvidia" ]]; then
  # Skip switcherooctl for NVIDIA GPUs; its PRIME offload env vars
  # (__NV_PRIME_RENDER_OFFLOAD, __GLX_VENDOR_LIBRARY_NAME, etc.)
  # crash DaVinci Resolve on hybrid GPU systems
  "$DAVINCI_BIN"
elif dbus_socket="$(get_host_dbus_socket)"; then
  DBUS_SYSTEM_BUS_ADDRESS="unix:path=$dbus_socket" switcherooctl launch "$DAVINCI_BIN"
else
  echo "Warning: Could not find host DBus system_bus_socket mount." >&2
  switcherooctl launch "$DAVINCI_BIN"
fi
